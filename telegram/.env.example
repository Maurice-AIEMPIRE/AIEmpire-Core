# ============================================
# GALAXIA OS TELEGRAM BOT CONFIGURATION
# ============================================

# Telegram Bot Tokens (Primary + Fallback)
BOT_TOKEN=your_primary_bot_token_here
DEVELOPER_CHAT_ID=your_chat_id_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# LLM Configuration (Ollama via LiteLLM)
MODEL_ENDPOINT=http://localhost:4000/api/v1/chat/completions
PRIMARY_MODEL=qwen3:14b
FALLBACK_MODEL=qwen3:8b
HEAVY_MODEL=qwen3:32b
LLM_TIMEOUT=120

# Orchestrator Configuration
ORCHESTRATOR_HOST=localhost
ORCHESTRATOR_PORT=8765
ORCHESTRATOR_POLLING_INTERVAL=5

# System Paths
BOT_LOG_DIR=/var/log/galaxia-bot
BOT_STATE_DIR=/var/lib/galaxia-bot

# Whitelist Chat IDs (comma-separated)
ALLOWED_CHAT_IDS=your_chat_id_here

# Monitoring
MONITORING_ENABLED=true
METRICS_PORT=9090
