{
  "$schema": "https://registry.lobe.ai/v1/skills/schema",
  "version": "1.0.0",
  "registry": {
    "namespace": "aiempire",
    "name": "AIEmpire Skills Registry",
    "description": "Official registry for AIEmpire distributed skills",
    "url": "https://github.com/Maurice-AIEMPIRE/AIEmpire-Core",
    "maintainer": "Maurice Pfeifer"
  },
  "skills": {
    "nucleus": {
      "id": "aiempire/nucleus",
      "name": "NUCLEUS",
      "type": "orchestrator",
      "version": "1.0.0",
      "enabled": true,
      "description": "Empire Orchestrator - Routes tasks to correct teams with quality gates",
      "author": "AIEmpire-Core",
      "manifest": ".claude/skills/nucleus/SKILL.md",
      "category": "operations",
      "tags": ["orchestration", "routing", "quality-gates", "state-management"],
      "inputs": {
        "task": {
          "type": "string",
          "description": "Natural language task description or structured command"
        },
        "context": {
          "type": "object",
          "description": "Pipeline state and agent registry"
        }
      },
      "outputs": {
        "routing": {
          "type": "object",
          "description": "Task routing decisions and team assignments"
        },
        "status": {
          "type": "string",
          "enum": ["ROUTED", "QUEUED", "ESCALATED"]
        }
      },
      "triggers": ["[STATUS]", "[SPAWN]", "[EXPORT]", "multi-team"],
      "dependencies": [],
      "performance": {
        "concurrency": 10,
        "timeout_ms": 30000,
        "cache": true
      }
    },
    "legal-timeline": {
      "id": "aiempire/legal-timeline",
      "name": "Legal Timeline Builder",
      "type": "analyzer",
      "version": "1.0.0",
