      "description": "Build chronological case timelines with facts and critical dates",
      "author": "AIEmpire-Core",
      "manifest": ".claude/skills/legal-timeline/SKILL.md",
      "category": "legal",
      "tags": ["legal", "timeline", "chronology", "evidence"],
      "team": "legal",
      "triggers": ["timeline", "chronology", "dates", "case-history"]
    },
    "legal-evidence": {
