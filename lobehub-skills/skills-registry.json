  "distribution": {
    "channels": {
      "github": {
        "enabled": true,
        "url": "https://github.com/Maurice-AIEMPIRE/AIEmpire-Core/releases",
        "format": "tar.gz"
      },
      "npm": {
        "enabled": false,
        "package": "@aiempire/skills"
      },
      "docker": {
        "enabled": true,
        "registry": "ghcr.io",
        "image": "ghcr.io/maurice-aiempire/aiempire-skills"
      }
    }
