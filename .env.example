# ==============================================================
# AIEmpire-Core - Environment Variables
# Copy to .env and fill in your values
# ==============================================================

# --- PRIMARY: Anthropic/Claude API (OpenClaw Default Model) ---
# Claude Sonnet 4.6 = default fuer alle OpenClaw Agent Workflows
# Ohne diesen Key laufen Tier 3 Jobs nicht (critical, planning, QA)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- PRIMARY: Moonshot/Kimi API (Tier 2 Cloud + Kimi Swarm) ---
MOONSHOT_API_KEY=sk-your-moonshot-api-key-here

# --- OPTIONAL: Google Gemini API ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- OPTIONAL: Google Cloud (Vertex AI) ---
GOOGLE_CLOUD_PROJECT=ai-empire-486415
GOOGLE_CLOUD_REGION=europe-west4

# --- OPTIONAL: Ollama (local models, kostenlos) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- OPTIONAL: GitHub Integration ---
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_REPO=Maurice-AIEMPIRE/AIEmpire-Core

# --- OPTIONAL: X/Twitter API (fuer Auto-Posting) ---
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# --- OPTIONAL: Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ==============================================================
# Model Routing (nach Kosten optimiert):
#   Ollama 85%  → kostenlos, lokal
#   Kimi    5%  → guenstig, cloud
#   Sonnet  8%  → claude-sonnet-4-6, fuer Agent Workflows
#   Haiku 1.5%  → claude-haiku-4-5, guenstige Cloud-Fallback
#   Opus  0.5%  → claude-opus-4-6, nur kritische Entscheidungen
# ==============================================================
